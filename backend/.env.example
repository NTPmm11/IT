# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่าให้ตรงเครื่องตัวเอง: cp .env.example .env
PORT=4000

DB_HOST=localhost
DB_PORT=1433
DB_USER=sa
DB_PASSWORD=
DB_NAME=CR

# ลิงก์กลับหน้าอนุมัติที่แนบไปในอีเมล (ต้องตรงกับ port ที่ frontend รันอยู่ — Vite default คือ 5173)
FRONTEND_URL=http://localhost:5173

# ไม่ตั้งค่า SMTP_HOST ไว้ = ระบบใช้ Ethereal (กล่องจดหมายปลอมสำหรับ dev) แทนอัตโนมัติ
# ใช้งานจริงค่อยเติมค่าพวกนี้:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
